# Crée le fichier .gitignore (sous Git Bash)
cat > .gitignore << EOF
### IntelliJ IDEA ###
.idea/
*.iws
*.iml
*.ipr
out/
.gradle/
build/

### Eclipse ###
.classpath
.project
.settings/
bin/
target/

### NetBeans ###
nbproject/private/
build/
nbbuild/
dist/
nbdist/
nbactions.xml
nb-configuration.xml

### VS Code ###
.vscode/

### Java ###
*.class
*.jar
*.war
*.ear
*.log
*.lock
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

### Spring Boot ###
HELP.md
!/mvnw
!/mvnw.cmd
!/mvn/wrapper/maven-wrapper.jar

### Logs ###
logs/
*.log

### OS files ###
.DS_Store
Thumbs.db
EOF